# ─────────────────────────────────────────────
# FICHIER .env.example — COPIER EN .env
# Ne jamais committer le vrai .env sur GitHub !
# ─────────────────────────────────────────────

# Port sur lequel tourne le serveur Express
PORT=5000

# URL de connexion à PostgreSQL
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:Sonny2801@localhost:5432/delice_pro"

# Clé secrète pour signer les tokens JWT
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="delice-pro-super-secret-jwt-key-2025-very-long-string-minimum-32-chars"

# Durée de validité du token JWT (ex: 7d = 7 jours, 24h = 24 heures)
JWT_EXPIRES_IN="7d"

# ─── Cloudinary (upload logo entreprise) ───
# Créer un compte gratuit sur cloudinary.com
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Environnement ───
NODE_ENV="development"

# ─── CORS (origine autorisée pour le frontend) ───
FRONTEND_URL="http://localhost:5173"
